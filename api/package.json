{
  "name": "aria-stripe-api",
  "version": "1.0.0",
  "description": "Aria Infrastructure Queen - Stripe billing API for infrastructure services",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "test": "jest --runInBand",
    "test:e2e": "jest --runInBand --testPathPattern=e2e",
    "test:unit": "jest --testPathPattern=unit",
    "lint": "eslint src/ tests/"
  },
  "dependencies": {
    "express": "^4.21.0",
    "stripe": "^14.14.0",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "dotenv": "^16.4.5",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^6.3.4",
    "eslint": "^8.57.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 30000
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
